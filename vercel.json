{
  "functions": {
    "backend/api/index.ts": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/api/index.ts?path=/$1"
    },
    {
      "source": "/((?!api|_next|static).*)",
      "destination": "/index.html"
    }
  ]
}