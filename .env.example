# WinWave Production Environment Variables
# Copy this file to .env and fill in your actual values

# ── Production Site URL ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://winwave-official.vercel.app/

# ── Supabase Configuration ──────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── PKPay Payment Gateway ───────────────────────────────────────
Payout_API_key=your_pkpay_api_key
Payout_API_secret=your_pkpay_api_secret
Merchant_ID=your_merchant_id
Webhook_secret=your_webhook_secret

# ── Admin Security ──────────────────────────────────────────────
ADMIN_SECRET_ID=3399944
ADMIN_INTERNAL_MUTATION_KEY=your_admin_mutation_key

# ── Webhook Configuration (Optional Overrides) ──────────────────
# VERCEL_URL is automatically set by Vercel in production
# DEV_WEBHOOK_BASE=your_ngrok_url_for_development
# PROD_WEBHOOK_BASE=https://winwave-official.vercel.app

# ── Game Engine ─────────────────────────────────────────────────
WINGO_HMAC_SECRET=your_wingo_hmac_secret
SMART_RISK_ENABLED=true

# ── Server Configuration ────────────────────────────────────────
PORT=3000
NODE_ENV=production