# Supabase (frontend - safe to expose, shipped in the browser bundle)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase (backend / serverless only - NEVER expose to the frontend)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PKPay payment gateway (backend / serverless only - NEVER expose to the frontend)
MERCHANT_ID=your_merchant_id
PAY_IN_KEY=your_pay_in_key
PAY_IN_SECRET=your_pay_in_secret
PAYOUT_KEY=your_payout_key
PAYOUT_SECRET=your_payout_secret
PKPAY_WEBHOOK_SECRET=your_webhook_secret
